#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define NAME_LEN 50

// Structure definition
struct Vehicle {
    int id;
    char model[NAME_LEN];
    char type[NAME_LEN];
    float mileage;
    int year;
};

// Function declarations
void addVehicle(struct Vehicle **fleet, int *count);
void displayVehicles(struct Vehicle *fleet, int count);
void searchVehicle(struct Vehicle *fleet, int count);
void updateVehicle(struct Vehicle *fleet, int count);
void deleteVehicle(struct Vehicle **fleet, int *count);
void clearInputBuffer();

// Main function
int main() {
    struct Vehicle *fleet = NULL;
    int count = 0;
    int choice;

    while (1) {
        printf("\n==============================\n");
        printf(" VEHICLE FLEET MANAGEMENT\n");
        printf("==============================\n");
        printf("1. Add Vehicle\n");
        printf("2. Display All Vehicles\n");
        printf("3. Search Vehicle\n");
        printf("4. Update Vehicle\n");
        printf("5. Delete Vehicle\n");
        printf("6. Exit\n");
        printf("==============================\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                addVehicle(&fleet, &count);
                break;
            case 2:
                displayVehicles(fleet, count);
                break;
            case 3:
                searchVehicle(fleet, count);
                break;
            case 4:
                updateVehicle(fleet, count);
                break;
            case 5:
                deleteVehicle(&fleet, &count);
                break;
            case 6:
                free(fleet);
                printf("Exiting program...\n");
                return 0;
            default:
                printf("Invalid choice! Try again.\n");
        }
    }
}

// Function to clear buffer
void clearInputBuffer() {
    while (getchar() != '\n');
}

// Add Vehicle (CREATE)
void addVehicle(struct Vehicle **fleet, int *count) {
    *fleet = (struct Vehicle *)realloc(*fleet, (*count + 1) * sizeof(struct Vehicle));

    if (*fleet == NULL) {
        printf("Memory allocation failed!\n");
        exit(1);
    }

    printf("\nEnter Vehicle ID: ");
    scanf("%d", &(*fleet)[*count].id);

    printf("Enter Model: ");
    scanf("%s", (*fleet)[*count].model);

    printf("Enter Type: ");
    scanf("%s", (*fleet)[*count].type);

    printf("Enter Mileage: ");
    scanf("%f", &(*fleet)[*count].mileage);

    printf("Enter Manufacturing Year: ");
    scanf("%d", &(*fleet)[*count].year);

    (*count)++;

    printf("Vehicle added successfully!\n");
}

// Display Vehicles (READ)
void displayVehicles(struct Vehicle *fleet, int count) {
    if (count == 0) {
        printf("\nNo vehicles available!\n");
        return;
    }

    printf("\n--- Vehicle List ---\n");

    for (int i = 0; i < count; i++) {
        printf("\nVehicle %d\n", i + 1);
        printf("ID: %d\n", fleet[i].id);
        printf("Model: %s\n", fleet[i].model);
        printf("Type: %s\n", fleet[i].type);
        printf("Mileage: %.2f\n", fleet[i].mileage);
        printf("Year: %d\n", fleet[i].year);
        printf("-------------------------\n");
    }
}

// Search Vehicle (READ - specific)
void searchVehicle(struct Vehicle *fleet, int count) {
    int id, found = 0;

    if (count == 0) {
        printf("\nNo vehicles to search!\n");
        return;
    }

    printf("\nEnter Vehicle ID to search: ");
    scanf("%d", &id);

    for (int i = 0; i < count; i++) {
        if (fleet[i].id == id) {
            printf("\nVehicle Found!\n");
            printf("ID: %d\n", fleet[i].id);
            printf("Model: %s\n", fleet[i].model);
            printf("Type: %s\n", fleet[i].type);
            printf("Mileage: %.2f\n", fleet[i].mileage);
            printf("Year: %d\n", fleet[i].year);
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Vehicle not found!\n");
    }
}

// Update Vehicle (UPDATE)
void updateVehicle(struct Vehicle *fleet, int count) {
    int id, found = 0;

    if (count == 0) {
        printf("\nNo vehicles to update!\n");
        return;
    }

    printf("\nEnter Vehicle ID to update: ");
    scanf("%d", &id);

    for (int i = 0; i < count; i++) {
        if (fleet[i].id == id) {
            printf("\nEnter new Model: ");
            scanf("%s", fleet[i].model);

            printf("Enter new Type: ");
            scanf("%s", fleet[i].type);

            printf("Enter new Mileage: ");
            scanf("%f", &fleet[i].mileage);

            printf("Enter new Year: ");
            scanf("%d", &fleet[i].year);

            printf("Vehicle updated successfully!\n");
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Vehicle not found!\n");
    }
}

// Delete Vehicle (DELETE)
void deleteVehicle(struct Vehicle **fleet, int *count) {
    int id, index = -1;

    if (*count == 0) {
        printf("\nNo vehicles to delete!\n");
        return;
    }

    printf("\nEnter Vehicle ID to delete: ");
    scanf("%d", &id);

    for (int i = 0; i < *count; i++) {
        if ((*fleet)[i].id == id) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        printf("Vehicle not found!\n");
        return;
    }

    for (int i = index; i < *count - 1; i++) {
        (*fleet)[i] = (*fleet)[i + 1];
    }

    (*count)--;

    *fleet = (struct Vehicle *)realloc(*fleet, (*count) * sizeof(struct Vehicle));

    printf("Vehicle deleted successfully!\n");
}
